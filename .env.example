# Copy this file to .env and fill in the real values.
# Do not commit the real .env file.
#
# Alibaba Cloud Model Studio / DashScope OpenAI-compatible endpoint.
#
# New Zealand / international endpoint:
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
#
# Chinese mainland endpoint, if your key was created in that region:
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

LLM_CHAT_MODEL=qwen-plus
EMBEDDING_MODEL=text-embedding-v4
TOP_K=3
